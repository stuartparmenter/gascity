{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.gastownhall/orders-v2/common.schema.json",
  "title": "Orders v2 Common Types",
  "$defs": {
    "scope_kind": {
      "type": "string",
      "enum": ["city", "rig"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "root_store_ref": {
      "type": "string",
      "minLength": 1
    },
    "validation_error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {}
      },
      "additionalProperties": true
    },
    "session_link": {
      "type": "object",
      "required": ["project_id", "session_id", "session_name", "assignee"],
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "session_name": {
          "type": "string",
          "minLength": 1
        },
        "assignee": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "var_def": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "enum": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pattern": {
          "type": "string"
        },
        "derived_from": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "formula_recent_run": {
      "type": "object",
      "required": ["workflow_id", "status", "target", "started_at", "updated_at"],
      "properties": {
        "workflow_id": {
          "$ref": "#/$defs/workflow_id"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        }
      },
      "additionalProperties": true
    },
    "formula_summary": {
      "type": "object",
      "required": ["name", "description", "version", "var_defs", "run_count", "recent_runs"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "var_defs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/var_def"
          }
        },
        "run_count": {
          "type": "integer",
          "minimum": 0
        },
        "recent_runs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formula_recent_run"
          }
        }
      },
      "additionalProperties": true
    },
    "formula_preview_node": {
      "type": "object",
      "required": ["id", "title", "kind"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "scope_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "formula_preview_edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "formula_detail": {
      "type": "object",
      "required": ["name", "description", "version", "var_defs", "steps", "deps", "preview"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "var_defs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/var_def"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "deps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formula_preview_edge"
          }
        },
        "preview": {
          "type": "object",
          "required": ["nodes", "edges"],
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/formula_preview_node"
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/formula_preview_edge"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "monitor_feed_item": {
      "type": "object",
      "required": [
        "id",
        "type",
        "status",
        "title",
        "scope_kind",
        "scope_ref",
        "target",
        "started_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["exec", "formula"]
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "scope_kind": {
          "$ref": "#/$defs/scope_kind"
        },
        "scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        },
        "bead_id": {
          "type": "string"
        },
        "detail_available": {
          "type": "boolean"
        },
        "workflow_id": {
          "$ref": "#/$defs/workflow_id"
        },
        "root_bead_id": {
          "type": "string"
        },
        "root_store_ref": {
          "$ref": "#/$defs/root_store_ref"
        },
        "attached_bead_id": {
          "type": "string"
        },
        "logical_bead_id": {
          "type": "string"
        },
        "run_detail_available": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "workflow_bead": {
      "type": "object",
      "required": ["id", "title", "status", "kind", "metadata"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "step_ref": {
          "type": "string"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "logical_bead_id": {
          "type": "string"
        },
        "scope_ref": {
          "type": "string"
        },
        "assignee": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "workflow_dep": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "logical_attempt": {
      "type": "object",
      "required": ["bead_id", "status", "attempt"],
      "properties": {
        "bead_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "started_at": {
          "$ref": "#/$defs/timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/timestamp"
        },
        "summary": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "logical_node": {
      "type": "object",
      "required": ["id", "title", "kind", "status", "metadata"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "scope_ref": {
          "type": "string"
        },
        "current_bead_id": {
          "type": "string"
        },
        "attempt_badge": {
          "type": "string"
        },
        "attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_attempt": {
          "type": "integer",
          "minimum": 1
        },
        "attempts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/logical_attempt"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "session_link": {
          "$ref": "#/$defs/session_link"
        }
      },
      "additionalProperties": true
    },
    "logical_edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "scope_group": {
      "type": "object",
      "required": ["scope_ref", "label", "member_logical_node_ids"],
      "properties": {
        "scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "member_logical_node_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "layout_hint": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "workflow_snapshot": {
      "type": "object",
      "required": [
        "workflow_id",
        "root_bead_id",
        "root_store_ref",
        "scope_kind",
        "scope_ref",
        "beads",
        "deps",
        "logical_nodes",
        "logical_edges",
        "scope_groups",
        "partial",
        "resolved_root_store",
        "stores_scanned",
        "snapshot_version"
      ],
      "properties": {
        "workflow_id": {
          "$ref": "#/$defs/workflow_id"
        },
        "root_bead_id": {
          "type": "string",
          "minLength": 1
        },
        "root_store_ref": {
          "$ref": "#/$defs/root_store_ref"
        },
        "scope_kind": {
          "$ref": "#/$defs/scope_kind"
        },
        "scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "beads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflow_bead"
          }
        },
        "deps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflow_dep"
          }
        },
        "logical_nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/logical_node"
          }
        },
        "logical_edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/logical_edge"
          }
        },
        "scope_groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scope_group"
          }
        },
        "partial": {
          "type": "boolean"
        },
        "resolved_root_store": {
          "$ref": "#/$defs/root_store_ref"
        },
        "stores_scanned": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "snapshot_version": {
          "type": "integer",
          "minimum": 0
        },
        "snapshot_event_seq": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "workflow_event": {
      "type": "object",
      "required": [
        "workflow_id",
        "root_bead_id",
        "root_store_ref",
        "scope_kind",
        "scope_ref",
        "watch_generation",
        "event_seq",
        "workflow_seq",
        "event_ts",
        "event_type",
        "bead",
        "changed_fields",
        "logical_node_id"
      ],
      "properties": {
        "workflow_id": {
          "$ref": "#/$defs/workflow_id"
        },
        "root_bead_id": {
          "type": "string",
          "minLength": 1
        },
        "root_store_ref": {
          "$ref": "#/$defs/root_store_ref"
        },
        "scope_kind": {
          "$ref": "#/$defs/scope_kind"
        },
        "scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "watch_generation": {
          "type": "string",
          "minLength": 1
        },
        "event_seq": {
          "type": "integer",
          "minimum": 0
        },
        "workflow_seq": {
          "type": "integer",
          "minimum": 0
        },
        "event_ts": {
          "$ref": "#/$defs/timestamp"
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "bead": {
          "$ref": "#/$defs/workflow_bead"
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflow_dep"
          }
        },
        "logical_node_id": {
          "type": "string",
          "minLength": 1
        },
        "attempt_summary": {
          "type": "object"
        },
        "scope_group_delta": {
          "type": "object"
        },
        "requires_resync": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "orders_v2_contract": {
      "type": "object",
      "required": ["contract_version", "artifact_hash"],
      "properties": {
        "contract_version": {
          "type": "string",
          "minLength": 1
        },
        "artifact_hash": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "orders_v2_capabilities": {
      "type": "object",
      "required": [
        "monitor",
        "launch",
        "workflow_snapshot",
        "workflow_live",
        "pool_targets",
        "bead_picker",
        "orders_v2_contract"
      ],
      "properties": {
        "monitor": {
          "type": "boolean"
        },
        "launch": {
          "type": "boolean"
        },
        "workflow_snapshot": {
          "type": "boolean"
        },
        "workflow_live": {
          "type": "boolean"
        },
        "pool_targets": {
          "type": "boolean"
        },
        "bead_picker": {
          "type": "boolean"
        },
        "orders_v2_contract": {
          "$ref": "#/$defs/orders_v2_contract"
        }
      },
      "additionalProperties": true
    }
  }
}
