# Gas City agent base image — system dependencies.
#
# Minimal runtime: OS packages, Bun, Socket Firewall, tmux, Claude Code CLI,
# Dolt, and the gcagent user. Developer tools live in Dockerfile.agent.
#
# Build:
#   make docker-base
#   # or: docker build -f contrib/k8s/Dockerfile.base -t gc-agent-base:latest .

FROM debian:trixie-slim

ENV DEBIAN_FRONTEND=noninteractive

# Bootstrap: curl and gnupg needed to add third-party apt repos.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gnupg ca-certificates gzip unzip \
    && rm -rf /var/lib/apt/lists/*

# Add GitHub CLI apt repo, then install everything in one pass.
RUN <<EOF
set -e
curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | gpg --dearmor -o /usr/share/keyrings/githubcli-archive-keyring.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list
apt-get update && apt-get install -y --no-install-recommends \
    gh \
    git \
    jq \
    lsof \
    ncurses-base \
    procps \
    sudo \
    tmux
rm -rf /var/lib/apt/lists/*
EOF

# Bun (installed to /opt/bun, not on PATH directly).
RUN curl -fsSL https://bun.sh/install | BUN_INSTALL=/opt/bun bash

# Socket Firewall + wrappers (matches dhi.io convention).
# /opt/socket/bin sits early in PATH and wraps bun/npm/npx through sfw.
# Real bun lives in /opt/bun/bin, only reachable via these shims.
# Set DHI_NO_SFW=true to bypass for debugging.
RUN <<EOF
set -e
mkdir -p /opt/socket/bin
ARCH=$(uname -m) && [ "$ARCH" = "aarch64" ] && ARCH="arm64"
curl -fsSL "https://github.com/SocketDev/sfw-free/releases/latest/download/sfw-free-linux-${ARCH}" -o /opt/socket/bin/sfw
chmod +x /opt/socket/bin/sfw

mkdir -p /usr/local/bin
ln -sf /opt/bun/bin/bun /usr/local/bin/node
for cmd in bun npm npx; do
  case "$cmd" in
    npx) real="/opt/bun/bin/bun x" ;;
    *)   real="/opt/bun/bin/bun" ;;
  esac
  cat > "/opt/socket/bin/${cmd}" <<SHIM
#!/bin/bash
if [ "\${DHI_NO_SFW}" = "true" ]; then
  exec ${real} "\$@"
else
  exec /opt/socket/bin/sfw ${real} "\$@"
fi
SHIM
  chmod +x "/opt/socket/bin/${cmd}"
done
EOF

ENV PATH="/opt/socket/bin:/opt/bun/bin:${PATH}"

# Dolt CLI — pinned version (keep in sync with deps.env and dolt-statefulset.yaml).
ARG DOLT_VERSION=1.85.0
RUN curl -fsSL https://github.com/dolthub/dolt/releases/download/v${DOLT_VERSION}/install.sh | bash

# Default non-root user for Claude Code (--dangerously-skip-permissions rejects root).
# When LINUX_USERNAME is set at runtime, the pod entrypoint creates a dynamic
# user via useradd and drops privileges via su. gcagent is kept as fallback.
RUN useradd -m -s /bin/bash gcagent \
    && echo "gcagent ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/gcagent \
    && chmod 0440 /etc/sudoers.d/gcagent

USER gcagent

# Dolt identity (required by bd init, not used for commits).
RUN dolt config --global --add user.name "gcagent" \
    && dolt config --global --add user.email "gcagent@gascity.local"

# Claude Code (native installer).
RUN curl -fsSL https://claude.ai/install.sh | bash

ENV HOME=/home/gcagent
ENV SHELL=/bin/bash
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PATH="/home/gcagent/.local/bin:/home/gcagent/.bun/bin:${PATH}"
